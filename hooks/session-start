#!/usr/bin/env bash
# SessionStart hook for roundtable plugin.
#
# Surfaces raw ROUNDTABLE_AUTO / ROUNDTABLE_DECISION_MODE env values into
# Claude Code's sessionContext so the /roundtable:workflow orchestrator can
# read authoritative state instead of inferring from higher-level harness
# signals (e.g. Claude Code Auto Mode system prompt).
#
# Design: see docs/design-docs/orchestrator-bootstrap-hardening.md
# DEC:    DEC-028 (scripts/ directory convention; raw-echo-only contract)

set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PLUGIN_ROOT="$(cd "${SCRIPT_DIR}/.." && pwd)"
PREFLIGHT_SCRIPT="${PLUGIN_ROOT}/scripts/preflight.sh"

if [ -x "$PREFLIGHT_SCRIPT" ]; then
    preflight_output="$("$PREFLIGHT_SCRIPT" 2>&1 || echo "PREFLIGHT error: scripts/preflight.sh exited non-zero")"
else
    preflight_output="PREFLIGHT error: scripts/preflight.sh not executable at ${PREFLIGHT_SCRIPT}"
fi

escape_for_json() {
    local s="$1"
    s="${s//\\/\\\\}"
    s="${s//\"/\\\"}"
    s="${s//$'\n'/\\n}"
    s="${s//$'\r'/\\r}"
    s="${s//$'\t'/\\t}"
    printf '%s' "$s"
}

session_context="<roundtable-preflight>
Captured at session start. These are the authoritative source for resolving auto_mode / decision_mode during /roundtable:workflow invocations.

${preflight_output}

HARD-GATE: The orchestrator must NOT conflate 'roundtable auto_mode' with any higher-level harness Auto Mode signal. Memory: feedback_roundtable_auto_mode_source. For role dispatch, see commands/workflow.md Step 3 role-form mapping table before invoking any role (skill vs agent).
</roundtable-preflight>"

escaped="$(escape_for_json "$session_context")"

if [ -n "${CURSOR_PLUGIN_ROOT:-}" ]; then
    printf '{\n  "additional_context": "%s"\n}\n' "$escaped"
elif [ -n "${CLAUDE_PLUGIN_ROOT:-}" ] && [ -z "${COPILOT_CLI:-}" ]; then
    printf '{\n  "hookSpecificOutput": {\n    "hookEventName": "SessionStart",\n    "additionalContext": "%s"\n  }\n}\n' "$escaped"
else
    printf '{\n  "additionalContext": "%s"\n}\n' "$escaped"
fi

exit 0
